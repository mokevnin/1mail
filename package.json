{
  "type": "module",
  "scripts": {
    "typespec:compile": "tsp compile typespec",
    "typespec:format": "tsp format typespec",
    "test": "node --env-file=.env --test test/**/*.test.ts",
    "start": "node --env-file=.env ./node_modules/.bin/fastify start -l info app.ts",
    "dev:api": "node --env-file=.env ./node_modules/.bin/fastify start -w -l info -P app.ts",
    "dev:web": "node --env-file=.env ./node_modules/.bin/vite",
    "dev": "overmind start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --fix .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:apply": "biome check --write .",
    "build": "vite build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
